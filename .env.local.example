# ============================================================
# Variáveis de ambiente - V8 on Fire
# ============================================================
# Copie este arquivo para .env.local (dev) e preencha com as keys reais.
# Em produção, configure as mesmas variáveis em:
#   Vercel → Project Settings → Environment Variables
#
# IMPORTANTE: NUNCA comite o arquivo .env.local — já está no .gitignore.
# ============================================================

# Supabase
# Obtenha em: Supabase Dashboard → Project Settings → API
#  - SUPABASE_URL : "Project URL" (ex.: https://xxxx.supabase.co)
#  - SUPABASE_KEY : "anon public" (chave pública anônima)
SUPABASE_URL=
SUPABASE_KEY=
